{
  "name": "@meeting-copilot/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first AI meeting copilot and smart meeting notes desktop app",
  "author": "Paulo Mats",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "pack:win": "electron-vite build && electron-builder --win --dir",
    "dist:win": "electron-vite build && electron-builder --win portable --x64",
    "dist:win:installer": "electron-vite build && electron-builder --win nsis --x64",
    "lint": "eslint src electron.vite.config.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "build": {
    "appId": "com.paulomats.meetingcopilot",
    "productName": "Meeting Copilot",
    "copyright": "Copyright © 2026 Paulo Mats",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/uiohook-napi/**/*"
    ],
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${target}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Meeting Copilot",
      "artifactName": "${productName}-${version}-setup-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@meeting-copilot/contracts": "workspace:*",
    "dotenv": "^16.5.0",
    "electron-store": "^10.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uiohook-napi": "^1.5.4",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  }
}
