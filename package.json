{
  "name": "meeting-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first desktop AI copilot for technical meetings",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:api": "pnpm --filter @meeting-copilot/contracts build && pnpm --filter @meeting-copilot/database build && pnpm --filter @meeting-copilot/api dev",
    "dev:desktop": "pnpm --filter @meeting-copilot/contracts build && pnpm --filter @meeting-copilot/desktop dev",
    "dev:desktop:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-windows-desktop.ps1",
    "dev:web": "pnpm --filter @meeting-copilot/web dev",
    "web:build": "pnpm --filter @meeting-copilot/web build",
    "web:preview": "pnpm --filter @meeting-copilot/web preview",
    "desktop:pack:win": "pnpm --filter @meeting-copilot/desktop pack:win",
    "desktop:dist:win": "pnpm --filter @meeting-copilot/desktop dist:win",
    "desktop:dist:win:installer": "pnpm --filter @meeting-copilot/desktop dist:win:installer",
    "format": "prettier --write .",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "db:generate": "pnpm --filter @meeting-copilot/database generate",
    "db:migrate": "pnpm --filter @meeting-copilot/database migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0"
  }
}
